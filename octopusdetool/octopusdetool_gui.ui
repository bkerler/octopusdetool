}

QLineEdit,
QComboBox,
QDateEdit {
    background-color: #ffffff;
    border: 1px solid #d7e2ec;
    border-radius: 8px;
    padding: 8px 10px;
}

QComboBox::drop-down,
QDateEdit::drop-down {
    border: none;
    width: 26px;
}

QPushButton {
    background-color: #eef4f9;
    border: 1px solid #d7e2ec;
    border-radius: 10px;
    padding: 9px 16px;
}

QPushButton:hover {
    background-color: #d7e2ec;
}

QPushButton#fetchDataButton {
    background-color: #0f766e;
    border-color: #0f766e;
    color: #ffffff;
    font: 600 10pt &quot;Segoe UI&quot;;
    min-height: 20px;
    padding: 11px 18px;
}

QPushButton#fetchDataButton:hover {
    background-color: #115e59;
}

QProgressBar {
    background-color: #eef4f9;
    border: 1px solid #d7e2ec;
    border-radius: 8px;
    min-height: 14px;
    text-align: center;
}

QProgressBar::chunk {
    background-color: #0f766e;
    border-radius: 8px;
}
